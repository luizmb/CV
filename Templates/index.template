<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>{{css}}</style>
</head>
<body>
<div class="header">
  <div class="hleft">
    <span class="hname">{{name}}</span>
    <span class="hlabel">{{label}}</span>
  </div>
  <div class="hright">
    <span class="hcontact">
      <strong>Contacts:</strong> {{email}} &nbsp;·&nbsp; {{phone}}<br>
      <strong>LinkedIn:</strong> {{linkedin}}<br>
      <strong>GitHub:</strong> {{github}}<br>
      {{location}} &nbsp;·&nbsp; {{visa}}
    </span>
  </div>
</div>
<div class="content">
<p class="summary">{{summary}}</p>
<section>
  <h2>Technical Skills</h2>
  {{#each skills skill-row}}
</section>
<section>
  <h2>Professional Experience</h2>
  {{#each jobs job}}
</section>
{{#if earlier_jobs earlier-section}}
{{#include footer}}
</div>
</body>
</html>
